<UserControl x:Class="OcrSnap.Screenshot.MagnifierControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="#AAFFFFFF" BorderThickness="1.5"
            CornerRadius="3"
            Background="#CC1E1E1E">
        <StackPanel>
            <!-- 放大圖區 -->
            <Border Width="160" Height="120" Margin="4,4,4,0"
                    BorderBrush="#55FFFFFF" BorderThickness="1">
                <Canvas x:Name="PixelCanvas" Width="160" Height="120" ClipToBounds="True">
                    <Image x:Name="ZoomImage" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <!-- 中心十字 -->
                    <Line x:Name="CrossH" Stroke="#FFFF0000" StrokeThickness="1" IsHitTestVisible="False"/>
                    <Line x:Name="CrossV" Stroke="#FFFF0000" StrokeThickness="1" IsHitTestVisible="False"/>
                </Canvas>
            </Border>
            <!-- 顏色色塊 + 文字 -->
            <StackPanel Orientation="Horizontal" Margin="6,3,6,4">
                <Border x:Name="ColorSwatch" Width="16" Height="16"
                        BorderBrush="White" BorderThickness="1" Margin="0,0,6,0"/>
                <TextBlock x:Name="ColorText" Foreground="White" FontSize="11"
                           VerticalAlignment="Center" FontFamily="Consolas"/>
            </StackPanel>
            <!-- 座標 -->
            <TextBlock x:Name="CoordText" Foreground="#BBFFFFFF" FontSize="10"
                       Margin="6,0,6,2" FontFamily="Consolas"/>
            <!-- 快捷鍵提示 -->
            <TextBlock Foreground="#88FFFFFF" FontSize="9" Margin="6,0,6,4"
                       Text="C 複製顏色　Shift 切換 RGB/HEX　Esc 取消"/>
        </StackPanel>
    </Border>
</UserControl>
