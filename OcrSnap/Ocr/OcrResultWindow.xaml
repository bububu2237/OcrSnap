<Window x:Class="OcrSnap.Ocr.OcrResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCR 辨識結果"
        Width="700" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="#FF141414">
    <Window.Resources>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#4D6EAF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3,24,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MaxDropDownHeight" Value="300"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#CCCCCC"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3A5080"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4D6EAF"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="PART_Root" SnapsToDevicePixels="True">
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            <Path x:Name="Arrow"
                                  Data="M0,0 L4,5 L8,0Z"
                                  Fill="#888888"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  IsHitTestVisible="False"/>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0" Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="#242424"
                                        BorderBrush="#555555" BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="{Binding ActualWidth, ElementName=PART_Root}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#FFFFFF"/>
                                <Setter TargetName="MainBorder" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Background="#FF141414">
        <!-- 工具列 -->
        <Border DockPanel.Dock="Top"
                Background="#1E1E1E"
                BorderBrush="#333333" BorderThickness="0,0,0,1"
                Padding="8,6">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource DarkBtn}" Content="全選並複製"
                        Click="BtnCopyAll_Click" Margin="0,0,6,0"/>
                <Rectangle Width="1" Height="16" Fill="#444444" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <ToggleButton x:Name="BtnShowBoxes" Style="{StaticResource DarkToggleBtn}"
                              Content="辨識框" Click="BtnShowBoxes_Click" IsChecked="False"
                              Margin="0,0,6,0"/>
                <Rectangle Width="1" Height="16" Fill="#444444" Margin="0,0,6,0" VerticalAlignment="Center"/>

                <!-- 語言選擇 -->
                <ComboBox x:Name="ModelBox" Style="{StaticResource DarkCombo}"
                          Width="120" VerticalAlignment="Center" Margin="0,0,6,0">
                    <ComboBoxItem Content="繁體中文" Tag="zh-Hant"/>
                    <ComboBoxItem Content="簡體中文" Tag="zh-Hans"/>
                    <ComboBoxItem Content="English"  Tag="en"/>
                    <ComboBoxItem Content="日本語"   Tag="ja"/>
                    <ComboBoxItem Content="한국어"   Tag="ko"/>
                </ComboBox>

                <Button x:Name="BtnReOcr" Style="{StaticResource DarkBtn}"
                        Click="BtnReOcr_Click" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ReOcrLabel" Text="重新辨識"/>
                        <ProgressBar x:Name="ReOcrSpinner" IsIndeterminate="True"
                                     Width="60" Height="3" Margin="6,0,0,0"
                                     VerticalAlignment="Center" Visibility="Collapsed"
                                     BorderThickness="0"
                                     Foreground="#4D9EFF" Background="Transparent"/>
                    </StackPanel>
                </Button>

                <Rectangle Width="1" Height="16" Fill="#444444" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="時間：" VerticalAlignment="Center" Foreground="#888888"/>
                <TextBlock x:Name="TimeLabel" VerticalAlignment="Center" Foreground="#AAAAAA"/>
            </WrapPanel>
        </Border>

        <!-- 主要內容 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="辨識文字"
                           FontWeight="SemiBold" Foreground="#AAAAAA"
                           Margin="8,6,8,4" FontSize="12"/>
                <TextBox x:Name="ResultText"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="False"
                         FontFamily="Consolas" FontSize="13"
                         Margin="4,0,4,4"
                         Background="#1A1A1A" Foreground="#E0E0E0"
                         BorderBrush="#333333" BorderThickness="1"
                         CaretBrush="White" SelectionBrush="#4D6EAF"
                         Padding="6"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#2A2A2A"/>

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="圖片預覽"
                           FontWeight="SemiBold" Foreground="#AAAAAA"
                           Margin="8,6,8,4" FontSize="12"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="#1A1A1A" Margin="4,0,4,4">
                    <Canvas x:Name="PreviewCanvas" Margin="4" Cursor="Cross"/>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
