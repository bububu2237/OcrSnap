<Window x:Class="OcrSnap.Annotation.AnnotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        SizeToContent="Height">
    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="ToggleButton">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#4D6EAF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF6B6B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConfirmBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#69D06A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SpinnerBar" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#4D9EFF"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3,22,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MaxDropDownHeight" Value="200"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#CCCCCC"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3A5080"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4D6EAF"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="PART_Root" SnapsToDevicePixels="True">
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            <Path x:Name="Arrow"
                                  Data="M0,0 L4,5 L8,0Z"
                                  Fill="#888888"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0"
                                  IsHitTestVisible="False"/>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0" Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="#1E1E1E"
                                        BorderBrush="#33FFFFFF" BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="{Binding ActualWidth, ElementName=PART_Root}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#FFFFFF"/>
                                <Setter TargetName="MainBorder" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 截圖區域 -->
        <Grid x:Name="ImageGrid" Grid.Row="0">
            <Image x:Name="CapturedImage" Stretch="None"
                   HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Canvas x:Name="DrawCanvas"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Background="Transparent" Cursor="Cross"/>

            <Border x:Name="ImageBorder"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    BorderBrush="#CCFFDD00" BorderThickness="2"
                    IsHitTestVisible="False"/>
        </Grid>

        <!-- Row 1: 工具列（雙行：上排工具，下排調色盤） -->
        <Border x:Name="Toolbar" Grid.Row="1"
                HorizontalAlignment="Center"
                Margin="0,5,0,8"
                Background="#E6141414"
                BorderBrush="#22FFFFFF" BorderThickness="1"
                CornerRadius="8" Padding="6,5">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="16" Opacity="0.5" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical">

                <!-- 上排：工具 + 線寬 + 動作 -->
                <StackPanel Orientation="Horizontal" x:Name="ToolbarPanel" VerticalAlignment="Center">
                    <ToggleButton x:Name="BtnRect" Style="{StaticResource ToolBtn}"
                                  ToolTip="矩形" Click="ToolBtn_Click" Tag="Rect">
                        <Rectangle Width="15" Height="11" Stroke="White" StrokeThickness="1.8" Fill="Transparent"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BtnPen" Style="{StaticResource ToolBtn}"
                                  ToolTip="畫筆" Click="ToolBtn_Click" Tag="Pen">
                        <TextBlock Text="✏" VerticalAlignment="Center"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BtnArrow" Style="{StaticResource ToolBtn}"
                                  ToolTip="箭頭" Click="ToolBtn_Click" Tag="Arrow">
                        <TextBlock Text="➤" VerticalAlignment="Center"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BtnText" Style="{StaticResource ToolBtn}"
                                  ToolTip="文字" Click="ToolBtn_Click" Tag="Text">
                        <TextBlock Text="T" FontWeight="Bold" VerticalAlignment="Center"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BtnMosaic" Style="{StaticResource ToolBtn}"
                                  ToolTip="高斯模糊" Click="ToolBtn_Click" Tag="Blur">
                        <Grid Width="18" Height="14" VerticalAlignment="Center">
                            <TextBlock Text="ab" FontSize="11" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <BlurEffect Radius="1.8" KernelType="Gaussian"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>
                    </ToggleButton>

                    <Rectangle Width="1" Height="20" Fill="#33FFFFFF" Margin="4,0"/>

                    <!-- 線寬 -->
                    <ComboBox x:Name="StrokeBox" Style="{StaticResource DarkCombo}"
                              Width="56" Margin="2,0" VerticalAlignment="Center"
                              SelectedIndex="1" ToolTip="線條粗細"
                              SelectionChanged="StrokeBox_SelectionChanged">
                        <ComboBoxItem Content="1 px"/>
                        <ComboBoxItem Content="2 px"/>
                        <ComboBoxItem Content="3 px"/>
                        <ComboBoxItem Content="5 px"/>
                    </ComboBox>

                    <Rectangle Width="1" Height="20" Fill="#33FFFFFF" Margin="4,0"/>

                    <Button Style="{StaticResource ActionBtn}" Click="BtnUndo_Click" ToolTip="復原 (Ctrl+Z)">
                        <TextBlock Text="↩" VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource ConfirmBtn}" Click="BtnCopy_Click" ToolTip="複製到剪貼簿">
                        <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                            <Canvas Width="14" Height="14">
                                <Rectangle Canvas.Left="4" Canvas.Top="0" Width="9" Height="9"
                                           Stroke="#CCCCCC" StrokeThickness="1.2"/>
                                <Rectangle Canvas.Left="0" Canvas.Top="4" Width="9" Height="9"
                                           Fill="#141414" Stroke="#CCCCCC" StrokeThickness="1.2"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnOcr" Style="{StaticResource ActionBtn}" Width="44"
                            Click="BtnOcr_Click" ToolTip="OCR 文字辨識">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="OcrLabel" Text="OCR" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <ProgressBar x:Name="OcrSpinner" Style="{StaticResource SpinnerBar}"
                                         IsIndeterminate="True" Width="32" Height="3"
                                         Margin="0,2,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ConfirmBtn}" Click="BtnPin_Click" ToolTip="釘選到畫面">
                        <TextBlock Text="📌" VerticalAlignment="Center"/>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="#33FFFFFF" Margin="4,0"/>

                    <Button Style="{StaticResource DangerBtn}" Click="BtnClose_Click" ToolTip="關閉 (Esc)">
                        <TextBlock Text="✕" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- 分隔線 -->
                <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,4,0,3"/>

                <!-- 下排：當前顏色 + 調色盤 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 當前顏色指示格 -->
                    <Border x:Name="CurrentColorSwatch"
                            Width="20" Height="20" CornerRadius="3" Margin="0,0,6,0"
                            BorderBrush="White" BorderThickness="1.5"
                            Background="Red" Cursor="Hand"
                            ToolTip="目前顏色"/>

                    <!-- 調色盤（由 code-behind 填入） -->
                    <WrapPanel x:Name="ColorPalette" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>
