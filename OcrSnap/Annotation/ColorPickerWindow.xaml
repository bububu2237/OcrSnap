<Window x:Class="OcrSnap.Annotation.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="選擇顏色" Width="280" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="選擇顏色" FontWeight="Bold" Margin="0,0,0,10"/>

        <WrapPanel x:Name="ColorPanel" Margin="0,0,0,12"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="自訂 HEX：" VerticalAlignment="Center"/>
            <TextBox x:Name="HexBox" Width="80" Margin="4,0"
                     Text="#FF0000" TextChanged="HexBox_TextChanged"/>
            <Border x:Name="PreviewSwatch" Width="24" Height="24"
                    BorderBrush="Gray" BorderThickness="1" Margin="4,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="確定" Width="60" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click"/>
            <Button Content="取消" Width="60" IsCancel="True" Click="BtnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
