<Window x:Class="OcrSnap.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OcrSnap 設定" Width="420"
        Icon="/Resources/Icons/app.ico"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF141414">
    <Window.Resources>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3,24,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MaxDropDownHeight" Value="300"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#CCCCCC"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3A5080"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4D6EAF"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="PART_Root" SnapsToDevicePixels="True">
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            <Path x:Name="Arrow" Data="M0,0 L4,5 L8,0Z"
                                  Fill="#888888" HorizontalAlignment="Right"
                                  VerticalAlignment="Center" Margin="0,0,8,0"
                                  IsHitTestVisible="False"/>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0" Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="#242424" BorderBrush="#555555" BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="{Binding ActualWidth, ElementName=PART_Root}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#FFFFFF"/>
                                <Setter TargetName="MainBorder" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 工具列 -->
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#1E1E1E"
                BorderBrush="#333333" BorderThickness="0,0,0,1"
                Padding="12,8">
            <TextBlock Text="截圖快捷鍵"
                       FontWeight="SemiBold" FontSize="12"
                       Foreground="#AAAAAA"/>
        </Border>

        <StackPanel Margin="16,12,16,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <CheckBox x:Name="ChkCtrl"  Content="Ctrl"  Margin="0,0,10,0"
                          Style="{StaticResource DarkCheck}" VerticalAlignment="Center"/>
                <CheckBox x:Name="ChkAlt"   Content="Alt"   Margin="0,0,10,0"
                          Style="{StaticResource DarkCheck}" VerticalAlignment="Center"/>
                <CheckBox x:Name="ChkShift" Content="Shift" Margin="0,0,10,0"
                          Style="{StaticResource DarkCheck}" VerticalAlignment="Center"/>
                <ComboBox x:Name="KeyBox" Width="110" VerticalAlignment="Center"
                          Style="{StaticResource DarkCombo}">
                    <ComboBoxItem Content="F1"           Tag="112"/>
                    <ComboBoxItem Content="F2"           Tag="113"/>
                    <ComboBoxItem Content="F3"           Tag="114"/>
                    <ComboBoxItem Content="F4"           Tag="115"/>
                    <ComboBoxItem Content="F5"           Tag="116"/>
                    <ComboBoxItem Content="Print Screen" Tag="44"/>
                </ComboBox>
            </StackPanel>

            <CheckBox x:Name="ChkRunAtStartup" Content="隨系統啟動"
                      Margin="0,0,0,16"
                      Style="{StaticResource DarkCheck}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="確定" Width="70" Margin="0,0,8,0"
                        IsDefault="True" Style="{StaticResource DarkBtn}"
                        Click="BtnOk_Click"/>
                <Button Content="取消" Width="70"
                        IsCancel="True" Style="{StaticResource DarkBtn}"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
