<Window x:Class="OcrSnap.Screenshot.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OcrSnap.Screenshot"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Cursor="Cross"
        ShowInTaskbar="False">
    <Grid x:Name="RootGrid">
        <!-- 截圖背景 -->
        <Image x:Name="ScreenImage" Stretch="None"
               HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- 暗色遮罩（四塊，圍繞選取區） -->
        <Canvas x:Name="MaskCanvas"/>

        <!-- 選取框 -->
        <Canvas x:Name="SelectionCanvas"/>

        <!-- 放大鏡（必須在 Canvas 裡才能用 Canvas.SetLeft/Top 定位） -->
        <Canvas x:Name="MagnifierCanvas" IsHitTestVisible="False">
            <local:MagnifierControl x:Name="Magnifier"
                                     Width="210" Height="195"
                                     IsHitTestVisible="False"/>
        </Canvas>
    </Grid>
</Window>
